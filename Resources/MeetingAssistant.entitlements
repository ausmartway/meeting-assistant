<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      The app is intentionally NOT sandboxed: ScreenCaptureKit system-audio
      capture and reading the meeting apps' windows do not work under the App
      Sandbox for a self-distributed build. Keychain + network are still used.
    -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
